# Database — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/agency_starter

# Payload — random secret string, used to sign tokens
PAYLOAD_SECRET=your-secret-here

# App URL — used for CORS, image domains, and live preview
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Preview — secret used to authorize the /next/preview route
PREVIEW_SECRET=your-preview-secret-here

# Vercel — automatically set on Vercel, used for production URL detection
VERCEL_PROJECT_PRODUCTION_URL=

# Cron — optional, used to authorize Payload job runner from external cron services
CRON_SECRET=
